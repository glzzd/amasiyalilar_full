    {
      "method": "GET",
      "path": "/api/public/news",
      "description": "Xəbərlər siyahısı",
      "query": {
        "page": "number",
        "limit": "number",
        "search": "string",
        "category": "string",
        "isConfirmed": "boolean"
      }
    },
    { "method": "GET", "path": "/api/public/news/:id", "description": "Xəbər detalı" },

